# Configuration Supabase
VITE_SUPABASE_URL=https://votre-projet.supabase.co
VITE_SUPABASE_ANON_KEY=votre_clé_anon_supabase

# HERE Maps API (pour le geocoding et les adresses)
VITE_HERE_API_KEY=votre_clé_here_api

# Google Analytics (optionnel)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Note: Ces variables sont compilées dans le build
# Elles doivent être configurées AVANT de lancer npm run build
